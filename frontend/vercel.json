{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://jusheng-jewelry-agent-production.up.railway.app/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://jusheng-jewelry-agent-production.up.railway.app/health"
    },
    {
      "source": "/docs",
      "destination": "https://jusheng-jewelry-agent-production.up.railway.app/docs"
    },
    {
      "source": "/openapi.json",
      "destination": "https://jusheng-jewelry-agent-production.up.railway.app/openapi.json"
    },
    {
      "source": "/static/:path*",
      "destination": "https://jusheng-jewelry-agent-production.up.railway.app/static/:path*"
    }
  ]
}
